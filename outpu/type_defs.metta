(: enhancer (-> $x ENHANCER))
(: promoter (-> $x PROMOTER))
(: super_enhancer (-> $x SUPER_ENHANCER))
(: non_coding_rna (-> $x NON_CODING_RNA))
(: pathway (-> $x PATHWAY))
(: reaction (-> $x REACTION))
(: regulatory_region (-> $x REGULATORY_REGION))
(: tfbs (-> $x TRANSCRIPTION_BINDING_SITE))
